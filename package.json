{
  "name": "tool-hub",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port 4000",
    "start:all": "node scripts/start-all.js",
    "build:all": "node scripts/build-all.js",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4000",
    "electron:dev": "concurrently \"vite --port 4000\" \"wait-on http://localhost:4000 && npx electron .\"",
    "electron:build": "tsc -b && vite build && npx electron-builder"
  },
  "dependencies": {
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "lamejs": "^1.2.1",
    "omggif": "^1.0.10",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "react-markdown": "^9.1.0",
    "react-router-dom": "^6.30.4",
    "remark-gfm": "^4.0.1",
    "wavesurfer.js": "^7.12.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.2.1",
    "electron": "^33.4.0",
    "electron-builder": "24.13.3",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.toolhub.app",
    "productName": "ToolHub",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
